{
    "layer": "top",
    "position": "top",
    "margin-top": 2,
    "margin-left": 2,
    "margin-right": 2,
    "height": 38,
    "spacing": 10,
    "modules-left": ["custom/launcher", "hyprland/window"],
    "modules-center": [
        "cpu",
        "memory",
        "custom/prev",
        "mpris",
        "custom/next",
        "hyprland/workspaces",
        "clock",
        "custom/performance",
        "battery",
        "custom/power"
    ],
    "modules-right": ["tray", "custom/swaync", "network", "bluetooth"],
    "custom/swaync": {
        "format": "ó°‚š",
        "on-click": "swaync-client -t",
        "tooltip": false
    },
    "custom/launcher": {
        "format": "ó°Ł‡",
        "on-click": "rofi -show drun",
        "tooltip": false
    },
    "hyprland/window": {
        "format": "Desktop\n{initialTitle}",
        "max-length": 20
    },
    "cpu": {
        "interval": 1,
        "format": "ó°»  {usage}%",
        "states": { "critical": 80 }
    },
    "tray": { "spacing": 8 },
    "memory": {
        "interval": 5,
        "format": "ó°Ť› {percentage}%"
    },
    "mpris": {
        "format": "{status_icon} {title}",
        "format-paused": "ó°Ź¤ {title}",
        "status-icons": {
            "playing": "ó°Ž†",
            "paused": "ó°Ź¤",
            "stopped": "ó°“›"
        },
        "max-length": 20,
        "min-length": 20,
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip": true,
        "tooltip-format": "{player}"
    },
    "custom/prev": {
        "exec": "playerctl status 2>/dev/null | grep -q 'Playing\\|Paused' && echo '{\"text\": \"ó°’®\"}' || echo '{\"text\": \"\"}'",
        "return-type": "json",
        "interval": 2,
        "on-click": "playerctl previous",
        "tooltip": false
    },
    "custom/next": {
        "exec": "playerctl status 2>/dev/null | grep -q 'Playing\\|Paused' && echo '{\"text\": \"ó°’­\"}' || echo '{\"text\": \"\"}'",
        "return-type": "json",
        "interval": 2,
        "on-click": "playerctl next",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": { "*": [1, 2, 3, 4, 5, 6] }
    },
    "clock": { "format": "{:%H:%M Â· %a, %d/%m}" },
    "custom/performance": {
        "exec": "~/.scripts/performance-status.sh",
        "interval": 2,
        "on-click": "~/.scripts/toggle-performance.sh",
        "format": "{}"
    },
    "battery": {
        "states": {
            "full": 100,
            "high": 90,
            "medium": 50,
            "low": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "custom/power": { "format": "âŹ»", "on-click": "wlogout" },
    "network": {
        "format-wifi": "ó°¤¨ {essid}",
        "format-disconnected": "ó°¤­ Disconnected",
        "on-click": "networkmanager_dmenu",
        "tooltip-format": "{essid} {signalStrength}%"
    },
    "bluetooth": { "format": "ó°‚Ż", "on-click": "blueman-manager" }
}
